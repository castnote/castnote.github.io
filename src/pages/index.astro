---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import EpisodeList from '@components/EpisodeList.astro';

const episodes = (await getCollection('episodes'))
  .filter((episode) => episode.data.rights_status !== 'local_only')
  .sort((a, b) => b.data.published_at.getTime() - a.data.published_at.getTime())
  .slice(0, 12);
---

<BaseLayout title="Podread" currentPath="/">
  <section class="section-head">
    <div>
      <p class="kicker">Chinese podcast reading</p>
      <h1>把值得精读的播客，整理成中文文章。</h1>
      <p class="lede">每期节目一篇中文稿，保留原始来源与授权状态，适合按节目、主题和时间持续阅读。</p>
    </div>
    <div class="toolbar">
      <a class="pill" href="/episodes/">全部文章</a>
      <a class="pill" href="/shows/">节目索引</a>
    </div>
  </section>

  <EpisodeList episodes={episodes} />
</BaseLayout>
